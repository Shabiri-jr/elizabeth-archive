# Supabase public values. These are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
NEXT_PUBLIC_SITE_URL=https://your-production-domain.example

# Server-only. Never expose this in client components or NEXT_PUBLIC_* values.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
APP_ORIGIN=https://your-production-domain.example

# Archive access controls.
ELIZABETH_ACCESS_CODE=replace-with-a-private-access-code
ELIZABETH_SESSION_SECRET=replace-with-a-long-random-session-secret-required-in-production
ADMIN_EMAILS=admin@example.com
